<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>OTP Verification</title>

<style>
/* Background animation */
@keyframes gradientMove {
  0% {background-position:0% 50%;}
  50% {background-position:100% 50%;}
  100% {background-position:0% 50%;}
}

/* Card fade animation */
@keyframes fadeIn {
  from {opacity:0; transform:translateY(15px);}
  to {opacity:1; transform:translateY(0);}
}

/* OTP pulse animation */
@keyframes pulse {
  0% {box-shadow:0 0 0 0 rgba(79,70,229,0.5);}
  70% {box-shadow:0 0 0 15px rgba(79,70,229,0);}
  100% {box-shadow:0 0 0 0 rgba(79,70,229,0);}
}

.card{
  animation:fadeIn 1s ease;
}

.header{
  background:linear-gradient(270deg,#4f46e5,#7c3aed,#9333ea);
  background-size:400% 400%;
  animation:gradientMove 6s ease infinite;
}

.otp-box{
  animation:pulse 2s infinite;
}
</style>

</head>

<body style="margin:0;padding:0;background:#f3f6fb;font-family:Arial,Helvetica,sans-serif;">

<table width="100%" cellspacing="0" cellpadding="0" style="padding:40px 0;">
<tr>
<td align="center">

<table class="card" width="520" cellspacing="0" cellpadding="0"
style="background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 12px 30px rgba(0,0,0,0.08);">

<!-- Header -->
<tr>
<td class="header" style="padding:30px;text-align:center;color:white;">
<h1 style="margin:0;font-size:26px;">OTP Verification</h1>
<p style="margin:6px 0 0 0;font-size:14px;opacity:0.9;">
Secure login confirmation
</p>
</td>
</tr>

<!-- Content -->
<tr>
<td style="padding:35px 40px;color:#444;font-size:16px;line-height:1.6;">

<p>Hello <strong><%= name %></strong>,</p>

<p>Please use the OTP below to verify your account.</p>

<!-- OTP -->
<div style="text-align:center;margin:30px 0;">
<div class="otp-box"
style="
display:inline-block;
padding:18px 45px;
font-size:36px;
letter-spacing:8px;
font-weight:bold;
color:#4f46e5;
background:#f5f7ff;
border-radius:10px;
border:2px dashed #cfd6ff;
">
<%= otp %>
</div>
</div>

<p style="text-align:center;font-size:14px;color:#777;">
This code will expire in <b>2 minutes</b>.
</p>

<!-- Button -->
<div style="text-align:center;margin:30px 0;">
<a href="#"
style="
background:#4f46e5;
color:white;
padding:12px 30px;
border-radius:6px;
text-decoration:none;
font-size:15px;
display:inline-block;
transition:0.3s;
">
Verify Account
</a>
</div>

<p style="font-size:14px;color:#777;">
If you did not request this OTP, please ignore this email.
</p>

</td>
</tr>

<!-- Footer -->
<tr>
<td style="background:#f9fafc;padding:20px;text-align:center;font-size:13px;color:#999;">
© <%= new Date().getFullYear() %> Your Company
</td>
</tr>

</table>

</td>
</tr>
</table>

</body>
</html>